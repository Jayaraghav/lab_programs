   "source": [
    "import spacy\n",
    "nlp = spacy.load(\"en_core_web_sm\")\n",
    "text = \"Narendra Modi met Stalin on March 15,2026 in Delhi\"\n",
    "doc = nlp(text)\n",
    "for ent in doc.ents:\n",
    "    if ent.label_ in [\"PERSON\", \"DATE\", \"GPE\", \"ORG\"]:\n",
    "        print(f\"{ent.label_}: {ent.text}\")"
   ]
